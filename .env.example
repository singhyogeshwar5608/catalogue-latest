# Dev server is pinned to port 3000 (`npm run dev`). If you see EADDRINUSE, stop the other
# process using 3000 (another `next dev`, Docker, etc.) or run: npx --yes kill-port 3000
#
# IMPORTANT: Save .env / .env.local as UTF-8 (Notepad "Save as" → Encoding: UTF-8).
# UTF-16 files are ignored by Next.js — env vars (including Upstash) will be missing.

# Browser API base when not using the dev proxy (see `getApiRequestBaseUrl` in `src/lib/api.ts`).
# In local dev, fetches usually go to same-origin `/api/laravel` instead — see below.
NEXT_PUBLIC_BASE_URL=https://larawans.com
NEXT_PUBLIC_API_BASE_URL=https://larawans.com/api/v1/v1

# Local Laravel (optional): point the browser at your PHP server when you disable the proxy.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1/v1

# If requests still show 127.0.0.1:8000: stop dev server, run `npm run clean` or delete `.next`, then `npm run dev`.

# Dev proxy: `/api/laravel/*` is rewritten to Laravel (see `next.config.ts`). First match wins:
#   1) BACKEND_PROXY_TARGET  2) origin of NEXT_PUBLIC_API_BASE_URL  3) http://127.0.0.1:8000
# If (2) is production, subscription mock-complete stays disabled on that server. For local PHP
# while keeping NEXT_PUBLIC_* on production, set explicitly:
# BACKEND_PROXY_TARGET=http://127.0.0.1:8000

# In dev, API calls default to same-origin `/api/laravel` (no CORS to live server). To force direct API:
# NEXT_PUBLIC_USE_API_PROXY=0
# BACKEND_PROXY_TARGET=https://larawans.com

# Server RSC + GET /api/stores: Laravel public origin. **If larawans.com in DNS = Next only, use a subdomain.**
# Highest priority for SSR. Same app as backend APP_URL, but use host that serves PHP in browser (JSON):
#   Local PHP:  LARAVEL_SSR_BASE_URL=http://127.0.0.1:8000
#   Live:        LARAVEL_SSR_BASE_URL=https://api.larawans.com
# Then set the browser API to the same host (see NEXT_PUBLIC_API_BASE_URL below) or CORS 404s.
# LARAVEL_SSR_BASE_URL=
# Legacy alias (overridden by LARAVEL_SSR_BASE_URL if both set):
# LARAVEL_API_BASE_URL=

# Upstash Redis — used only by Next.js routes under /api/* (withCache). https://console.upstash.com
# The browser still talks to Laravel via NEXT_PUBLIC_API_BASE_URL unless you proxy through /api.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
# Optional key prefix if multiple apps share one Redis (with or without trailing colon):
# CACHE_KEY_PREFIX=catelog
#
# After setting secrets: restart `npm run dev`, open GET http://localhost:3000/api/cache/status
# then GET http://localhost:3000/api/stores?limit=5 twice — Upstash Data Browser should show keys like `app:stores:list?...`
#
# Optional: max age in seconds for `stores` API cache (limits staleness if DB is changed outside the app).
# Leave unset to rely only on Laravel → POST /api/cache/invalidate (set NEXT_CACHE_INVALIDATE_URL in backend/.env).
# CATALOG_SAFETY_TTL_SECONDS=900
#
# Optional: after Laravel POST/PUT/PATCH/DELETE on stores/products, call Next to purge Redis:
#   POST http://localhost:3000/api/cache/invalidate
#   Header: x-cache-invalidate-secret: <same value as below>
#   Body (optional): {"scopes":["stores"]} or ["stores","products"]
# In production, set a strong secret; in local dev you can omit it (invalidation allowed without header).
# CACHE_INVALIDATE_SECRET=your-random-string
#
# Live Laravel (separate host): set the SAME value in backend/.env as NEXT_CACHE_INVALIDATE_SECRET and set
# NEXT_CACHE_INVALIDATE_URL so Laravel can POST /api/cache/invalidate after store create/update/delete and
# super-admin free-trial changes (clears Redis `stores:*` so new stores appear on the Next UI).
